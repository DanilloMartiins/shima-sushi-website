SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=seushimasushi
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Server Configuration
SERVER_PORT=8080

# Security - JWT (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-strong-secret-min-32-chars
JWT_ACCESS_EXPIRATION=PT15M
JWT_REFRESH_EXPIRATION=P7D

# CORS - Comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Image Upload Configuration
IMAGE_UPLOAD_BASE_DIR=uploads/products
IMAGE_UPLOAD_MAX_SIZE=5242880

# Admin User (created on first startup)
ADMIN_NAME=Seu Shima Sushi Admin
ADMIN_EMAIL=admin@seushimasushi.com
ADMIN_PASSWORD=change-me-in-dev

# Logging Levels (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_SECURITY=INFO

# Profile-specific settings
# Development: SPRING_PROFILES_ACTIVE=dev (defaults to H2 in-memory DB for testing)
# Production: SPRING_PROFILES_ACTIVE=prod (requires all DB vars, JWT_SECRET, CORS origins)
