{
  "name": "seu-shima-sushi",
  "version": "1.0.0",
  "private": true,
  "description": "Projeto principal Seu Shima Sushi - Angular Frontend e Spring Boot Backend",
  "scripts": {
    "dev": "concurrently -k -n FRONT,BACK -c cyan,green \"npm run dev:angular\" \"npm run dev:backend\"",
    "dev:angular": "npm --prefix frontend-angular start",
    "dev:backend": "seuShimaSushi-backend\\mvnw.cmd -f seuShimaSushi-backend/pom.xml spring-boot:run",
    "install:all": "npm install && npm --prefix frontend-angular install",
    "build": "npm --prefix frontend-angular run build",
    "lint": "npm --prefix frontend-angular run lint",
    "format": "prettier \"**/*.{html,css,js,ts,json,md}\" --write",
    "format:check": "prettier \"**/*.{html,css,js,ts,json,md}\" --check"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.3.3"
  }
}
