SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=SeuShimaSushi
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Server Configuration
SERVER_PORT=8080

# Security - JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your_secure_random_key_here

# CORS - Comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Image Upload Configuration
IMAGE_UPLOAD_BASE_DIR=uploads/products
IMAGE_UPLOAD_MAX_SIZE=5242880

# Admin User (created on first startup)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Clerk API (Secret Key from Clerk Dashboard)
CLERK_SECRET_KEY=sk_your_clerk_secret_here

# Logging Levels
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_SECURITY=INFO
